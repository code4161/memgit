{
  "openapi": "3.1.0",
  "info": {
    "title": "memgit Memory API",
    "description": "Version-controlled persistent memory store for AI assistants. Stores facts, rules, preferences, and lessons learned across sessions. Use search_memories at the start of every session to retrieve relevant context. Use save_memory whenever you learn something worth remembering for future sessions. memgit is the authority for entity STATUS (tr tracker memories); files are downstream. When a memory corrects an old one, pass supersedes=[old-slug] \u2014 superseded memories are hidden from search by default.",
    "version": "0.6.0"
  },
  "servers": [
    {
      "url": "http://localhost:7474",
      "description": "Local memgit HTTP server (run: memgit serve --http)"
    }
  ],
  "paths": {
    "/memories/search": {
      "post": {
        "operationId": "search_memories",
        "summary": "Search memories by relevance",
        "description": "Search the persistent memory store for facts, rules, and lessons relevant to the current task. CALL THIS at the start of every session, before answering questions about past work, before applying preferences the user may have stated before, or whenever you are unsure whether you have prior context on a topic. Returns memories ranked by BM25 relevance \u2014 only what matters, not everything.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "query"
                ],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Natural-language description of what you want to recall. Examples: 'user preferences for code style', 'how does the Instagram pipeline work', 'what trading rules should I follow'"
                  },
                  "top_k": {
                    "type": "integer",
                    "default": 8,
                    "maximum": 30,
                    "description": "Max results to return. Use 15-20 for broad topic discovery."
                  },
                  "type_filter": {
                    "type": "string",
                    "enum": [
                      "fb",
                      "us",
                      "pj",
                      "rf",
                      "cn",
                      "lx",
                      "co",
                      "tr"
                    ],
                    "description": "fb=feedback, us=user, pj=project, rf=reference, cn=convention, lx=lesson, co=core (per-project operating guide), tr=tracker (LIVE status of one entity, slug '<entity>-status', updated by re-saving the same slug; memgit is the authority for this status, files are downstream)"
                  },
                  "include_superseded": {
                    "type": "boolean",
                    "default": false,
                    "description": "Also score memories that a newer memory supersedes (hidden by default)."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ranked list of matching memories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Memory"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/memories/{slug}": {
      "get": {
        "operationId": "get_memory",
        "summary": "Get a single memory by slug",
        "description": "Fetch a single memory by its exact slug identifier. CALL THIS when search_memories returned a relevant slug and you need the full details (why, when to apply, tags).",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Kebab-case memory slug, e.g. 'ig-pipeline-no-fallback'"
          }
        ],
        "responses": {
          "200": {
            "description": "Full memory object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Memory"
                }
              }
            }
          },
          "404": {
            "description": "Memory not found"
          }
        }
      },
      "put": {
        "operationId": "save_memory",
        "summary": "Save or update a memory",
        "description": "Persist a new fact, rule, preference, or lesson to the memory store for future sessions. CALL THIS whenever you learn something the user would want you to remember next time \u2014 a preference they stated, a rule they corrected you on, a project decision, a lesson from a mistake, or a reference to an external system. Do NOT save ephemeral or task-specific details. If a memory with the same slug already exists, this updates it.",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Short kebab-case identifier, unique per memory. Examples: 'user-prefers-terse-responses', 'trading-confirm-only-orders'"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "rule"
                ],
                "properties": {
                  "rule": {
                    "type": "string",
                    "description": "The primary fact or rule to remember. Write as a declarative statement: 'always X', 'never Y', 'Z is located at ...'"
                  },
                  "type_code": {
                    "type": "string",
                    "enum": [
                      "fb",
                      "us",
                      "pj",
                      "rf",
                      "cn",
                      "lx",
                      "co",
                      "tr"
                    ],
                    "default": "fb",
                    "description": "fb=feedback, us=user, pj=project, rf=reference, cn=convention, lx=lesson, co=core (per-project operating guide), tr=tracker (LIVE status of one entity, slug '<entity>-status', updated by re-saving the same slug; memgit is the authority for this status, files are downstream)"
                  },
                  "why": {
                    "type": "string",
                    "description": "Why this rule exists \u2014 the incident, reason, or motivation. Optional but strongly recommended."
                  },
                  "when": {
                    "type": "string",
                    "description": "When or where to apply this rule."
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Topic tags for filtering, e.g. ['instagram', 'trading']"
                  },
                  "priority": {
                    "type": "integer",
                    "enum": [
                      1,
                      2,
                      3
                    ],
                    "default": 2,
                    "description": "1=low (background context), 2=medium (apply when relevant), 3=critical (always loaded)"
                  },
                  "body": {
                    "type": "string",
                    "description": "Full long-form detail behind the rule \u2014 stored losslessly."
                  },
                  "supersedes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Slugs of memories this one REPLACES (corrections, updated decisions). Superseded memories stop surfacing in search automatically."
                  },
                  "related": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Slugs of related memories (cross-reference, not replacement)."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Memory saved or updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ]
                    },
                    "action": {
                      "type": "string",
                      "enum": [
                        "saved",
                        "updated"
                      ]
                    },
                    "slug": {
                      "type": "string"
                    },
                    "warnings": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Per-edge relation problems (unknown slug kept, cycle edge dropped)."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/memories": {
      "get": {
        "operationId": "list_memories",
        "summary": "List all memories (compact)",
        "description": "List all memories, returning slug + rule for each. CALL THIS to browse what is stored or discover memory slugs for get_memory. For finding relevant memories on a topic, use search_memories instead \u2014 it is faster and ranked.",
        "parameters": [
          {
            "name": "type_filter",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "fb",
                "us",
                "pj",
                "rf",
                "cn",
                "lx",
                "co",
                "tr"
              ]
            },
            "description": "Filter by type: fb=feedback, us=user, pj=project, rf=reference, cn=convention, lx=lesson"
          },
          {
            "name": "min_priority",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Only return memories at or above this priority (1=all, 2=medium+, 3=critical only)"
          }
        ],
        "responses": {
          "200": {
            "description": "Compact list of all memories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "slug": {
                        "type": "string"
                      },
                      "type": {
                        "type": "string"
                      },
                      "priority": {
                        "type": "integer"
                      },
                      "rule": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/checkpoints": {
      "get": {
        "operationId": "get_checkpoint_log",
        "summary": "Get checkpoint history",
        "description": "Show recent checkpoint history \u2014 when memories were last synced and what changed. CALL THIS to understand how fresh the memory store is.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 5
            },
            "description": "Max checkpoints to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Checkpoint history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "sha": {
                        "type": "string"
                      },
                      "timestamp": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "message": {
                        "type": "string"
                      },
                      "added": {
                        "type": "integer"
                      },
                      "modified": {
                        "type": "integer"
                      },
                      "removed": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/resume": {
      "get": {
        "operationId": "resumeSession",
        "summary": "Where-we-left-off digest: last checkpoints, staged work, recent + critical memories",
        "parameters": [
          {
            "name": "checkpoints",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 5
            },
            "description": "Recent checkpoints to include"
          },
          {
            "name": "recent",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Recently updated memories to include"
          }
        ],
        "responses": {
          "200": {
            "description": "Resume context",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Memory": {
        "type": "object",
        "required": [
          "slug",
          "type",
          "priority",
          "rule"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "description": "Unique kebab-case identifier"
          },
          "type": {
            "type": "string",
            "enum": [
              "fb",
              "us",
              "pj",
              "rf",
              "cn",
              "lx",
              "co",
              "tr"
            ],
            "description": "fb=feedback, us=user, pj=project, rf=reference, cn=convention, lx=lesson, co=core (per-project operating guide), tr=tracker (LIVE status of one entity, slug '<entity>-status', updated by re-saving the same slug; memgit is the authority for this status, files are downstream)"
          },
          "priority": {
            "type": "integer",
            "enum": [
              1,
              2,
              3
            ],
            "description": "1=low, 2=medium, 3=critical (always loaded)"
          },
          "rule": {
            "type": "string",
            "description": "The primary fact or rule"
          },
          "why": {
            "type": "string",
            "description": "Why this rule exists"
          },
          "when": {
            "type": "string",
            "description": "When or where to apply"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "score": {
            "type": "number",
            "description": "BM25 relevance score (only present in search results)"
          },
          "supersedes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Slugs this memory replaces"
          },
          "related": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}